rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utenti ───────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if true;
      allow create, delete: if request.auth != null && request.auth.uid == uid;
      // Scrittura propria o aggiornamento di followers/followRequests da parte di utenti autenticati
      allow update: if request.auth != null && (
        request.auth.uid == uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followRequests']) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'followRequests'])
      );

      // Notifiche: solo il proprietario legge/aggiorna/cancella,
      // ma QUALSIASI utente autenticato può CREARE (per notificare altri)
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null;
      }
    }

    // ── Sondaggi ─────────────────────────────────────────────────
    match /polls/{pollId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Commenti
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        // Può cancellare: l'autore del commento OPPURE l'autore del sondaggio
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.uid ||
          request.auth.uid == get(/databases/$(database)/documents/polls/$(pollId)).data.authorId
        );

        // Risposte ai commenti
        match /replies/{replyId} {
          allow read: if true;
          allow create: if request.auth != null;
          // Può cancellare: l'autore della risposta OPPURE l'autore del sondaggio
          allow delete: if request.auth != null && (
            request.auth.uid == resource.data.uid ||
            request.auth.uid == get(/databases/$(database)/documents/polls/$(pollId)).data.authorId
          );
        }
      }
    }

    // ── Conversazioni DM ─────────────────────────────────────────
    match /conversations/{convId} {
      allow read, write: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);

      match /messages/{msgId} {
        allow read, write: if request.auth != null &&
          (resource == null || request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
      }
    }

  }
}
