# Copia questo file in .env e inserisci i tuoi valori Firebase
# NON committare mai il file .env su GitHub

VITE_FIREBASE_API_KEY=la-tua-api-key
VITE_FIREBASE_AUTH_DOMAIN=il-tuo-progetto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=il-tuo-progetto
VITE_FIREBASE_STORAGE_BUCKET=il-tuo-progetto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=il-tuo-sender-id
VITE_FIREBASE_APP_ID=il-tuo-app-id
